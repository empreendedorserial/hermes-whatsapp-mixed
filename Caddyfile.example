# 🔒 Caddyfile - Configuração de Proxy Reverso e SSL Automático
# Se você deseja acessar o Dashboard ou Pty do Hermes pela Web de forma segura (HTTPS)
# substitua 'hermes.seu-dominio.com' pelo seu domínio real.

hermes.seu-dominio.com {
    # Redireciona todas as requisições para a porta do Hermes Agent Dashboard
    reverse_proxy hermes-agent:9119 {
        # Importante: Caddy precisa encaminhar WebSockets corretamente para o terminal interativo funcionar!
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
}
